generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Alert {
  id               String   @id @default(uuid())
  title            String
  description      String
  category         String
  severity         String
  summary          String   @default("")
  suggested_action String   @default("")
  reason           String   @default("")
  confidence       String   @default("high")
  source           String   @default("User")
  location         String?
  date             String
  resolved         Boolean  @default(false)
  affects_me       Boolean  @default(false)
  created_at       DateTime @default(now())
  verification_count    Int     @default(0)
  verification_status   String  @default("pending")
  checklist_state       Boolean[] @default([])

  @@index([category])
  @@index([severity])
  @@index([resolved])
  @@index([source])
  @@index([affects_me])
  @@index([created_at])
  @@index([verification_status])
}

model UserPreference {
  id          String   @id @default("default")
  concerns    String[] @default([])
  severities   String[] @default([])
  theme       String   @default("system")
  quiet_start String?
  quiet_end   String?
  user_location        String?   // "San Francisco, CA"
  user_coordinates     Json?     // {lat: 37.7749, lng: -122.4194}
  location_radius      Float?    @default(25.0) // miles
  location_enabled     Boolean   @default(false)
  updated_at  DateTime @updatedAt
}

model Guardian {
  id         String   @id @default(uuid())
  name       String
  label      String?
  created_at DateTime @default(now())
}

model AlertVerification {
  id          String   @id @default(uuid())
  alert_id    String
  verification_type String  // 'verified', 'fake', 'disputed'
  created_at   DateTime @default(now())
  
  @@index([alert_id])
  @@index([verification_type])
}

